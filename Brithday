    <script>
      const openSurprise = document.getElementById("openSurprise");
      const curtain = document.getElementById("curtain");
      const heroSubtitle = document.getElementById("heroSubtitle");
      const heroHint = document.getElementById("heroHint");
      const heroText = document.getElementById("heroText");
      const floatingContainer = document.getElementById("floatingContainer");

      const wishButton = document.getElementById("wishButton");
      const wishText = document.getElementById("wishText");
      const wishModal = document.getElementById("wishModal");
      const modalWish = document.getElementById("modalWish");
      const closeModal = document.getElementById("closeModal");
      const finalButton = document.getElementById("finalButton");
      const finalMessage = document.getElementById("finalMessage");
      const confettiCanvas = document.getElementById("confettiCanvas");
      const ctx = confettiCanvas.getContext("2d");
      const revealItems = document.querySelectorAll("[data-reveal]");
      const memoryButtons = document.querySelectorAll(".reveal-memory");
      let isConfettiAnimating = false;
      let confettiParticles = [];
      let confettiAnimationId = null;

      const wishes = [
        "May your year be filled with victories, happiness, and unforgettable moments Goldu.",
        "Keep chasing your dreams and achieving new milestones Goldu.",
        "May every challenge make you stronger and every success make you proud Goldu.",
        "Wishing you endless happiness, good health, and success in all your endeavors Goldu.",
        "May this birthday mark the beginning of your best year yet Goldu.",
      ];
      const finalText =
        "Wishing you happiness, success, good health, and countless achievements in the years ahead. May you continue inspiring others through your dedication, confidence, and hard work. Keep shining, keep growing, and keep achieving great things. Happy Birthday, Goldu! 🥋🎂✨";
      const memoryMessages = [
        "You made ordinary days unforgettable.",
        "Every moment with you became a favorite memory.",
        "Thank you for all the laughter.",
        "Life became brighter because of you.",
        "Your presence turns simple moments into magic.",
        "With you, every day feels like a celebration.",
      ];

      const colors = [
        "#f472b6",
        "#c084fc",
        "#fb7185",
        "#60a5fa",
        "#f9a8d4",
        "#a78bfa",
      ];

      function setCanvasSize() {
        confettiCanvas.width = window.innerWidth;
        confettiCanvas.height = window.innerHeight;
      }

      window.addEventListener("resize", setCanvasSize);
      setCanvasSize();

      function createFloatingElements(count = 30) {
        const types = ["heart", "star", "sparkle"];
        for (let i = 0; i < count; i++) {
          const element = document.createElement("div");
          const type = types[Math.floor(Math.random() * types.length)];
          element.className = `floating-item ${type}`;
          const size = 8 + Math.random() * 20;
          element.style.width = `${size}px`;
          element.style.height = `${size}px`;
          element.style.left = `${Math.random() * 95}%`;
          element.style.top = `${100 + Math.random() * 40}%`;
          element.style.opacity = 0.4 + Math.random() * 0.6;
          element.style.animationDuration = `${10 + Math.random() * 16}s`;
          element.style.animationDelay = `${-Math.random() * 10}s`;
          element.style.transform = `rotate(${Math.random() * 360}deg)`;
          element.style.filter = `blur(${Math.random() * 0.6}px)`;
          floatingContainer.appendChild(element);
        }
      }

      function revealScroll() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.2 },
        );
        revealItems.forEach((item) => observer.observe(item));
      }

      function openCurtains() {
        curtain.classList.add("curtain-open");
        openSurprise.disabled = true;
        setTimeout(() => {
          curtain.style.display = "none";
        }, 2200);
        setTimeout(() => {
          heroSubtitle.classList.add("visible");
          heroHint.classList.add("visible");
        }, 3600);
      }

      function typeFinalMessage() {
        if (finalMessage.classList.contains("visible")) return;
        finalMessage.classList.add("visible");
        finalMessage.textContent = "";
        let index = 0;
        const interval = setInterval(() => {
          finalMessage.textContent += finalText.charAt(index);
          index += 1;
          if (index >= finalText.length) clearInterval(interval);
        }, 36);
      }

      function getRandomWish() {
        return wishes[Math.floor(Math.random() * wishes.length)];
      }

      function getRandomColor() {
        return colors[Math.floor(Math.random() * colors.length)];
      }

      class ConfettiParticle {
        constructor() {
          this.reset();
        }
        reset() {
          this.x = Math.random() * confettiCanvas.width;
          this.y = Math.random() * -confettiCanvas.height;
          this.size = 6 + Math.random() * 10;
          this.velocityX = (Math.random() - 0.5) * 4;
          this.velocityY = 2 + Math.random() * 5;
          this.rotation = Math.random() * 360;
          this.rotationSpeed = (Math.random() - 0.5) * 10;
          this.color = getRandomColor();
          this.opacity = 0.8 + Math.random() * 0.2;
        }
        update() {
          this.x += this.velocityX;
          this.y += this.velocityY;
          this.rotation += this.rotationSpeed;
          this.opacity -= 0.002;
          if (this.y > confettiCanvas.height || this.opacity <= 0) {
            this.reset();
            this.y = -20;
          }
        }
        draw() {
          ctx.save();
          ctx.translate(this.x, this.y);
          ctx.rotate((this.rotation * Math.PI) / 180);
          ctx.fillStyle = this.color;
          ctx.globalAlpha = this.opacity;
          ctx.fillRect(
            -this.size / 2,
            -this.size / 2,
            this.size,
            this.size * 0.4,
          );
          ctx.restore();
        }
      }

      function initializeConfetti() {
        confettiParticles = Array.from(
          { length: 150 },
          () => new ConfettiParticle(),
        );
      }

      function animateConfetti() {
        ctx.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);
        confettiParticles.forEach((p) => {
          p.update();
          p.draw();
        });
        confettiAnimationId = requestAnimationFrame(animateConfetti);
      }

      function burstParticles() {
        if (isConfettiAnimating) return;
        isConfettiAnimating = true;
        initializeConfetti();
        animateConfetti();
        setTimeout(() => {
          cancelAnimationFrame(confettiAnimationId);
          ctx.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);
          isConfettiAnimating = false;
        }, 2600);
      }

      function openWishModal() {
        const wish = getRandomWish();
        wishText.textContent = wish;
        modalWish.textContent = wish;
        wishModal.classList.add("active");
        wishModal.setAttribute("aria-hidden", "false");
        burstParticles();
      }

      function closeWishModal() {
        wishModal.classList.remove("active");
        wishModal.setAttribute("aria-hidden", "true");
      }

      function handleMemoryFlip(event) {
        const card = event.currentTarget.closest(".polaroid-card");
        card.classList.toggle("revealed");
        if (card.classList.contains("revealed")) {
          event.currentTarget.textContent = "Hide Memory";
        } else {
          event.currentTarget.textContent = "Reveal Secret Memory ❤️";
        }
      }

      function setupMemoryButtons() {
        memoryButtons.forEach((button, index) => {
          button.addEventListener("click", handleMemoryFlip);
        });
      }

      openSurprise.addEventListener("pointerdown", openCurtains, {
        once: true,
      });
      wishButton.addEventListener("click", openWishModal);
      closeModal.addEventListener("click", closeWishModal);
      wishModal.addEventListener("click", (event) => {
        if (event.target === wishModal) closeWishModal();
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeWishModal();
      });
      finalButton.addEventListener("click", typeFinalMessage);

      document.addEventListener("DOMContentLoaded", () => {
        createFloatingElements(32);
        revealScroll();
        setupMemoryButtons();
        const label = heroText.textContent;
        heroText.textContent = "";
        let idx = 0;
        const typingInterval = setInterval(() => {
          heroText.textContent += label[idx] || "";
          idx += 1;
          if (idx > label.length) {
            clearInterval(typingInterval);
            heroText.classList.remove("typing-line");
          }
        }, 65);
      });
    </script>
