<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Birthday Surprise</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      :root {
        --bg: #090812;
        --surface: rgba(255, 255, 255, 0.08);
        --surface-strong: rgba(255, 255, 255, 0.15);
        --text: #f8f4ff;
        --text-muted: rgba(248, 244, 255, 0.72);
        --accent: #dc2626;
        --accent-soft: rgba(244, 114, 182, 0.2);
        --accent-deep: #b91c1c;
        --rose-gold:  #ffd700;
        --shadow: 0 24px 90px rgba(15, 23, 42, 0.45);
        --border: rgba(255, 255, 255, 0.16);
      }
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Poppins", sans-serif;

      margin: 0;
  min-height: 100vh;
  font-family: 'Poppins', sans-serif;
  background:
    radial-gradient(circle at top left,
      rgba(220, 38, 38, 0.18),
      transparent 25%),
    radial-gradient(circle at bottom right,
      rgba(255, 215, 0, 0.12),
      transparent 30%),
    linear-gradient(
      180deg,
      #050505 0%,
      #0d0d0d 40%,
      #161616 100%
    );
  color: var(--text);
  overflow-x: hidden; color: var(--text);
        overflow-x: hidden;
      }
      button,
      a {
        font: inherit;
      }
      .glass-card {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.16);
        backdrop-filter: blur(22px);
        box-shadow: var(--shadow);
      }
      .curtain-shell {
        position: fixed;
        inset: 0;
        display: grid;
        place-items: center;
        z-index: 40;
        overflow: hidden;
        background: radial-gradient(
          circle at center,
          rgba(255, 255, 255, 0.08),
          transparent 34%
        );
      }
      .curtain-panel {
        position: absolute;
        top: 0;
        width: 55%;
        height: 100%;
        background: linear-gradient(
          160deg,
           #0a0a0a 0%,
  #151515 25%,
  #1f1f1f 50%,
  #2b0000 100%
        );
        background-image:
          radial-gradient(
            circle at top,
            rgba(255, 255, 255, 0.05),
            transparent 24%
          ),
          radial-gradient(
            circle at bottom,
            rgba(255, 255, 255, 0.04),
            transparent 20%
          );
        box-shadow:
          inset 0 0 45px rgba(0, 0, 0, 0.55),
          0 0 70px rgba(0, 0, 0, 0.4);
        border-right: 1px solid rgba(255, 255, 255, 0.08);
        transform: translateX(0);
        transition: transform 2s cubic-bezier(0.23, 1, 0.32, 1);
      }
      .curtain-panel.right {
        right: 0;
        left: auto;
        border-left: 1px solid rgba(255, 255, 255, 0.08);
      }
      .curtain-panel.left {
        left: 0;
      }
      .curtain-panel::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(255, 255, 255, 0.04),
          transparent 70%
        );
        opacity: 0.75;
      }
      .curtain-panel::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image: radial-gradient(
          circle at 50% 30%,
          rgba(255, 255, 255, 0.06),
          transparent 26%
        );
      }
      .curtain-open .curtain-panel.left {
        transform: translateX(-110%);
      }
      .curtain-open .curtain-panel.right {
        transform: translateX(110%);
      }
      .curtain-open .curtain-glow {
        transform: scale(12);
        opacity: 0.14;
      }
      .curtain-overlay {
        position: relative;
        z-index: 10;
        display: grid;
        place-items: center;
        width: 100%;
        height: 100%;
        text-align: center;
        padding: 2rem;
      }
      .curtain-button {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        padding: 1.25rem 2rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.12);
        color: #fff;
        text-shadow: 0 0 18px rgba(255, 255, 255, 0.25);
        box-shadow: 0 0 30px rgba(244, 114, 182, 0.24);
        cursor: pointer;
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease,
          background 0.25s ease;
        backdrop-filter: blur(18px);
        position: relative;
        animation: floatButton 4s ease-in-out infinite;
      }
      .curtain-button:hover {
        transform: scale(1.05);
        box-shadow: 0 0 45px rgba(244, 114, 182, 0.45);
        background: rgba(255, 255, 255, 0.18);
      }
      .curtain-button::before {
        content: "";
        position: absolute;
        inset: -10px;
        border-radius: 999px;
        background: radial-gradient(
          circle,
          rgba(244, 114, 182, 0.18),
          transparent 58%
        );
        opacity: 0.7;
        z-index: -1;
        filter: blur(10px);
      }
      .curtain-glow {
        position: absolute;
        inset: 50%;
        width: 20rem;
        height: 20rem;
        background: radial-gradient(
          circle,
          rgba(244, 114, 182, 0.35),
          transparent 60%
        );
        border-radius: 50%;
        opacity: 0.6;
        transform: scale(1);
        transition:
          transform 2s ease,
          opacity 1.6s ease;
      }
      @keyframes floatButton {
        0%,
        100% {
          transform: translateY(0) scale(1);
        }
        50% {
          transform: translateY(-8px) scale(1.02);
        }
      }
      .hero-section {
        position: relative;
        min-height: 100vh;
        padding: 5rem 1.5rem 4rem;
        display: grid;
        place-items: center;
        overflow: hidden;
      }
      .hero-background {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        background:
    radial-gradient(circle at top left,
      rgba(220,38,38,0.15),
      transparent 30%),
    radial-gradient(circle at bottom right,
      rgba(255,215,0,0.10),
      transparent 35%),
    linear-gradient(
      180deg,
      rgba(5,5,5,0.96),
      rgba(15,15,15,0.96)
    ); }
      .hero-mesh {
        position: absolute;
        inset: 0;
        background:
    radial-gradient(circle at 20% 30%,
      rgba(220,38,38,0.15),
      transparent 18%),
    radial-gradient(circle at 80% 15%,
      rgba(255,215,0,0.12),
      transparent 16%),
    radial-gradient(circle at 50% 70%,
      rgba(255,255,255,0.05),
      transparent 20%);
        opacity: 0.95;
        filter: blur(8px);
        animation: drift 22s linear infinite;
      }
      @keyframes drift {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-60px);
        }
      }
      .hero-content {
        position: relative;
        z-index: 10;
        max-width: 900px;
        width: 100%;
        text-align: center;
      }
      .hero-title {
        font-family: "Playfair Display", serif;
        font-size: clamp(3.5rem, 5vw, 6rem);
        line-height: 0.95;
        letter-spacing: -0.05em;
        margin: 0;
        color: #fff;
        text-shadow: 0 0 28px rgba(244, 114, 182, 0.18);
      }
      .hero-title span {
        display: inline-block;
      }
      .typing-line {
        border-right: 0.14em solid rgba(255, 255, 255, 0.8);
        white-space: nowrap;
        overflow: hidden;
        display: inline-block;
        animation:
          typing 3.5s steps(28, end) forwards,
          blink 0.8s step-end infinite alternate;
      }
      @keyframes typing {
        from {
          width: 0;
        }
        to {
          width: 100%;
        }
      }
      @keyframes blink {
        50% {
          border-color: transparent;
        }
      }
      .hero-subtitle {
        margin-top: 1.6rem;
        font-size: 1.25rem;
        color: var(--text-muted);
        opacity: 0;
        transform: translateY(14px);
        transition:
          opacity 0.9s ease,
          transform 0.9s ease;
      }
      .hero-subtitle.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .scroll-hint {
        margin-top: 3rem;
        display: inline-flex;
        align-items: center;
        gap: 0.9rem;
        opacity: 0;
        transform: translateY(16px);
        transition:
          opacity 0.9s ease 0.2s,
          transform 0.9s ease 0.2s;
        color: var(--text-muted);
      }
      .scroll-hint.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .arrow-bounce {
        display: inline-block;
        animation: bounce 1.6s infinite;
      }
      @keyframes bounce {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(8px);
        }
      }
      .floating-container {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 2;
      }
      .floating-item {
        position: absolute;
        will-change: transform, opacity;
        opacity: 0.85;
        animation: floatUp linear infinite;
      }
      .floating-item.heart {
        width: 18px;
        height: 18px;
      }
      .floating-item.star {
        width: 14px;
        height: 14px;
      }
      .floating-item.sparkle {
        width: 10px;
        height: 10px;
      }
      .floating-item.heart::before,
      .floating-item.heart::after {
        content: "";
        position: absolute;
        width: 12px;
        height: 18px;
        background: rgba(244, 114, 182, 0.96);
        border-radius: 50%;
        top: 0;
      }
      .floating-item.heart::before {
        left: 5px;
        transform: rotate(-45deg);
      }
      .floating-item.heart::after {
        left: 0;
        transform: rotate(45deg);
      }
      .floating-item.star::before,
      .floating-item.star::after {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
          circle,
          rgba(255, 255, 255, 0.96),
          rgba(248, 145, 255, 0.45)
        );
        transform: rotate(45deg);
        clip-path: polygon(
          50% 0%,
          61% 35%,
          98% 35%,
          68% 57%,
          79% 91%,
          50% 70%,
          21% 91%,
          32% 57%,
          2% 35%,
          39% 35%
        );
      }
      .floating-item.sparkle {
        border-radius: 50%;
        background: radial-gradient(
          circle,
          rgba(255, 255, 255, 0.9),
          rgba(244, 114, 182, 0.35)
        );
        box-shadow: 0 0 18px rgba(244, 114, 182, 0.2);
      }
      @keyframes floatUp {
        from {
          transform: translateY(0) scale(1);
        }
        to {
          transform: translateY(-130vh) scale(1.15);
          opacity: 0;
        }
      }
      .section-heading {
        font-family: "Playfair Display", serif;
        font-size: clamp(2.2rem, 4vw, 3rem);
        letter-spacing: -0.04em;
        margin: 0;
        line-height: 1.05;
      }
      .section-subtitle {
        color: var(--text-muted);
        margin-top: 0.9rem;
        max-width: 36rem;
      }
      .gallery-grid {
        display: grid;
        gap: 1.75rem;
        grid-template-columns: repeat(1, minmax(0, 1fr));
      }
      @media (min-width: 768px) {
        .gallery-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }
      @media (min-width: 1200px) {
        .gallery-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }
      }
      .polaroid-card {
        position: relative;
        perspective: 1200px;
        min-height: 9rem;
      }
      .polaroid-inner {
        width: 100%;
        min-height: 100%;
        transition: transform 0.8s ease;
        transform-style: preserve-3d;
      }
      .polaroid-card.revealed .polaroid-inner {
        transform: rotateY(180deg);
      }
      .polaroid-face {
        position: absolute;
        inset: 0;
        border-radius: 2rem;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.94);
        border: 1px solid rgba(255, 255, 255, 0.55);
        box-shadow: 0 25px 80px rgba(236, 89, 168, 0.399);
        backface-visibility: hidden;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }
      .polaroid-front {
        transform: rotateY(0deg);
      }
      .polaroid-back {
        transform: rotateY(180deg);
        padding: 2rem;
        background: linear-gradient(
          180deg,
          rgba(244, 114, 182, 0.12),
          rgba(168, 85, 247, 0.14)
        );
        color: #111827;
        display: grid;
        place-items: center;
        text-align: center;
      }
      .polaroid-image {
        width: 100%;
        height: 18rem;
        object-fit: cover;
        display: block;
      }
      .polaroid-meta {
        padding: 1.4rem 1.4rem 2rem;
      }
      .polaroid-meta h3 {
        margin: 0;
        font-size: 1.15rem;
        color: #0f172a;
      }
      .polaroid-meta p {
        margin: 0.75rem 0 0;
        color: #475569;
        line-height: 1.75;
        font-size: 0.95rem;
      }
      .polaroid-button {
        margin-top: 1.5rem;
        width: fit-content;
        padding: 0.9rem 1.4rem;
        border-radius: 999px;
        background: linear-gradient(
          135deg,
          rgba(168, 85, 247, 0.95),
          rgba(244, 114, 182, 0.95)
        );
        color: #fff;
        border: none;
        cursor: pointer;
        box-shadow: 0 18px 40px rgba(168, 85, 247, 0.24);
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease;
      }
      .polaroid-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 22px 55px rgba(168, 85, 247, 0.28);
      }
      .gallery-card {
        transform-origin: center;
        transition:
          transform 0.35s ease,
          box-shadow 0.35s ease;
      }
      .gallery-card:hover {
        transform: translateY(-10px) rotate3d(1, 1, 0, 1deg);
        box-shadow: 0 40px 120px rgba(20, 0, 60, 0.24);
      }
      .wish-section {
        position: relative;
        padding: 4rem 1.5rem 5rem;
        display: grid;
        place-items: center;
      }
      .wish-panel {
        width: min(100%, 56rem);
        padding: 3rem;
        border-radius: 2.5rem;
        border: 1px solid rgba(255, 255, 255, 0.16);
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(22px);
        box-shadow: var(--shadow);
        display: grid;
        gap: 1.4rem;
      }
      .wish-panel h2 {
        font-family: "Playfair Display", serif;
        margin: 0;
        font-size: clamp(2rem, 3.8vw, 3.4rem);
        line-height: 1.02;
      }
      .wish-panel p {
        margin: 0;
        color: var(--text-muted);
        max-width: 45rem;
        font-size: 1.05rem;
        line-height: 1.85;
      }
      .wish-button {
        width: fit-content;
        padding: 1rem 1.9rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.22);
        background: linear-gradient(
          135deg,
          rgba(244, 114, 182, 0.92),
          rgba(168, 85, 247, 0.9)
        );
        color: #fff;
        font-weight: 700;
        box-shadow: 0 18px 45px rgba(244, 114, 182, 0.28);
        cursor: pointer;
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease;
        animation: pulse 2.8s ease-in-out infinite;
      }
      .wish-button:hover {
        transform: translateY(-3px);
        box-shadow: 0 24px 60px rgba(244, 114, 182, 0.35);
      }
      @keyframes pulse {
        0%,
        100% {
          transform: scale(1);
        }
        50% {
          transform: scale(1.02);
        }
      }
      .wish-text {
        width: 100%;
        min-height: 8rem;
        border-radius: 2rem;
        background: rgba(15, 23, 42, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 2rem;
        display: grid;
        place-items: center;
        color: #f8f4ff;
        font-size: 1.3rem;
        line-height: 1.75;
        text-align: center;
        box-shadow: inset 0 0 28px rgba(255, 255, 255, 0.05);
      }
      .confetti-canvas {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 50;
      }
      .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(7, 8, 17, 0.82);
        backdrop-filter: blur(12px);
        display: grid;
        place-items: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.35s ease;
        z-index: 60;
      }
      .modal-backdrop.active {
        opacity: 1;
        pointer-events: auto;
      }
      .modal-card {
        width: min(92vw, 44rem);
        padding: 2.5rem;
        border-radius: 2rem;
        background: rgba(255, 255, 255, 0.09);
        border: 1px solid rgba(255, 255, 255, 0.18);
        backdrop-filter: blur(28px);
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
      }
      .modal-card::before {
        content: "";
        position: absolute;
        inset: -20%;
        background: radial-gradient(
          circle at top left,
          rgba(244, 114, 182, 0.22),
          transparent 35%
        );
        opacity: 0.9;
      }
      .modal-content {
        position: relative;
        z-index: 2;
        display: grid;
        gap: 1.4rem;
        text-align: center;
      }
      .modal-content h3 {
        margin: 0;
        font-family: "Playfair Display", serif;
        font-size: clamp(2.2rem, 4vw, 3rem);
        color: #fff;
      }
      .modal-content p {
        margin: 0;
        color: var(--text-muted);
        font-size: 1.05rem;
        line-height: 1.85;
      }
      .modal-close {
        margin: 0 auto;
        padding: 0.9rem 1.5rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.18);
        background: rgba(255, 255, 255, 0.12);
        color: #fff;
        cursor: pointer;
        transition:
          transform 0.25s ease,
          background 0.25s ease;
      }
      .modal-close:hover {
        transform: translateY(-2px);
        background: rgba(255, 255, 255, 0.18);
      }
      .final-section {
        padding: 4rem 1.5rem 5rem;
        display: grid;
        place-items: center;
        gap: 2rem;
      }
      .final-card {
        width: min(100%, 56rem);
        padding: 3rem;
        border-radius: 2.5rem;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.16);
        backdrop-filter: blur(22px);
        box-shadow: var(--shadow);
        display: grid;
        gap: 1.5rem;
        text-align: center;
      }
      .final-card h2 {
        margin: 0;
        font-family: "Playfair Display", serif;
        font-size: clamp(2.2rem, 4vw, 3.2rem);
        letter-spacing: -0.04em;
      }
      .final-button {
        width: fit-content;
        margin: 0 auto;
        padding: 1rem 1.8rem;
        border-radius: 999px;
        background: linear-gradient(
          135deg,
          rgba(244, 114, 182, 0.95),
          rgba(168, 85, 247, 0.95)
        );
        border: 1px solid rgba(255, 255, 255, 0.18);
        color: #fff;
        font-weight: 700;
        box-shadow: 0 22px 58px rgba(244, 114, 182, 0.24);
        cursor: pointer;
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease;
      }
      .final-button:hover {
        transform: translateY(-3px);
      }
      .final-message {
        opacity: 0;
        max-height: 0;
        overflow: hidden;
        transition:
          opacity 0.6s ease,
          max-height 0.6s ease;
        color: var(--text-muted);
        line-height: 1.95;
        font-size: 1.05rem;
      }
      .final-message.visible {
        opacity: 1;
        max-height: 28rem;
      }
      .footer {
        padding: 2rem 1.5rem 3rem;
        text-align: center;
        color: var(--text-muted);
        font-size: 0.95rem;
        display: grid;
        gap: 0.75rem;
      }
      .heartbeat {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font-weight: 600;
        color: #f472b6;
        animation: heartbeat 1.4s ease-in-out infinite;
      }
      @keyframes heartbeat {
        0%,
        100% {
          transform: scale(1);
        }
        40% {
          transform: scale(1.08);
        }
        60% {
          transform: scale(0.98);
        }
      }
      .reveal-item {
        opacity: 0;
        transform: translateY(24px);
        transition:
          opacity 0.9s ease,
          transform 0.9s ease;
      }
      .reveal-item.visible {
        opacity: 1;
        transform: translateY(0);
      }
    </style>
  </head>
  <body>
    <div id="curtain" class="curtain-shell">
      <div class="curtain-panel left"></div>
      <div class="curtain-panel right"></div>
      <div class="curtain-glow"></div>
      <div class="curtain-overlay">
        <div class="max-w-xl mx-auto text-center">
          <p class="text-sm uppercase tracking-[0.35em] text-pink-200/60 mb-6">
            A cinematic birthday surprise
          </p>
          <button id="openSurprise" class="curtain-button" type="button">
            🎁 Open Your Surprise
          </button>
        </div>
      </div>
    </div>

    <canvas id="confettiCanvas" class="confetti-canvas"></canvas>

    <section id="hero" class="hero-section">
      <div class="hero-background"></div>
      <div class="hero-mesh"></div>
      <div id="floatingContainer" class="floating-container"></div>
      <div class="hero-content">
        <h1 class="hero-title reveal-item">
          <span id="heroText" class="typing-line"
            >Happy Birthday, Goldu! 🥋🎂✨</span
          >
        </h1>
        <p id="heroSubtitle" class="hero-subtitle reveal-item">
          A special birthday surprise for one of the strongest and most
